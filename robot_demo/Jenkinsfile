pipeline {
    agent any

    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/zhenhtan/leaningProgram.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    echo "Creating virtual environment..."
                    python3 -m venv robot_env
                    source robot_env/bin/activate
                    echo "Installing Robot Framework..."
                    pip install robotframework
                '''
            }
        }

        stage('Run Robot Test') {
            steps {
                sh '''
                    echo "Running Robot test..."
                    source robot_env/bin/activate
                    cd robot_demo
                    robot example.robot
                '''
            }
        }
    }

    post {
        success {
            echo 'Test passed!'
        }
        failure {
            echo 'Test failed!'
        }
    }
}