# 目标网页（请确保你有合法抓取权限）
TARGET_URL=https://example.com/

# CSS 选择器；默认抓取 h1
CSS_SELECTOR=h1

# 抓取周期（分钟）
CRAWL_EVERY_MINUTES=1

# 请求头
USER_AGENT=CompliantCrawler/1.0 (+contact: your_email@example.com)

# 超时（秒）
REQUEST_TIMEOUT=15

# 是否检查 robots.txt（1=开启，0=关闭，不建议关闭）
CHECK_ROBOTS=1

# SQLite 文件路径
DB_PATH=data/crawler.db
